cat > .gitignore << 'EOF'
# Binaries and build artifacts
tmp/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test

# Database files
*.db
*.sqlite
*.sqlite3

# Environment variables
.env
.env.local
.env.*.local

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Go specific
vendor/

# Logs
*.log

# Fly.io secrets (if any)
.secrets/
EOF

cmd/seed